    {
      "name": "Submit word",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200 or 400\", function () {\r",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 400]);\r",
              "});\r",
              "\r",
              "if (pm.response.code === 200) {\r",
              "    const json = pm.response.json();\r",
              "\r",
              "    pm.test(\"Next player returned\", function () {\r",
              "        pm.expect(json.nextPlayer).to.exist;\r",
              "    });\r",
              "\r",
              "    pm.test(\"Match finished flag returned\", function () {\r",
              "        pm.expect(json.matchFinished).to.not.equal(undefined);\r",
              "    });\r",
              "\r",
              "    const current = pm.environment.get(\"currentPlayerId\");\r",
              "    const other = pm.environment.get(\"otherPlayerId\");\r",
              "    pm.environment.set(\"currentPlayerId\", other);\r",
              "    pm.environment.set(\"otherPlayerId\", current);\r",
              "} else {\r",
              "    pm.test(\"Bad request contains message\", function () {\r",
              "        pm.expect(pm.response.text()).to.not.eql(\"\");\r",
              "    });\r",
              "}\r",
              "console.log(\"Submit uses currentPlayerId:\", pm.environment.get(\"currentPlayerId\"));\r",
              "console.log(\"Response:\", pm.response.text());"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
