<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WordDuel.UI</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WordDuel.UI.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="dev-nav">
            <span>DEV</span>
            <button class="dev-btn active" onclick="showState('lobby')">Lobby</button>
            <button class="dev-btn" onclick="showState('waiting')">Waiting</button>
            <button class="dev-btn" onclick="showState('coin-flip')">CoinFlip</button>
            <button class="dev-btn" onclick="showState('player-turn')">PlayerTurn</button>
            <button class="dev-btn" onclick="showState('spectating')">Spectating</button>
            <button class="dev-btn" onclick="showState('round-result')">RoundResult</button>
            <button class="dev-btn" onclick="showState('match-result')">MatchResult</button>

            <div style="flex: 1;"></div>
            <button class="info-btn" onclick="togglePanel()">&#9432; game info</button>
        </nav>

        <div class="info-panel" id="dev-panel">
            <div class="info-row"><span class="info-key">game-state</span><span class="info-val" id="di-gamestate">Lobby</span></div>
            <div class="info-row"><span class="info-key">game-session</span><span class="info-val" id="di-session">null</span></div>
            <div class="info-row"><span class="info-key">round-state</span><span class="info-val" id="di-roundstate">null</span></div>
            <div class="info-row"><span class="info-key">current-player</span><span class="info-val" id="di-player">null</span></div>
        </div>
    </header>

    

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - WordDuel.UI - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
